{
  "compilerOptions": {
    "target": "ES2015",
    "lib": ["ES2015", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@src/*": [
        "./src/*"
      ],
      "@components/*": [
        "./public/components/*"
      ],
      "@docs/*": [
        "./public/doc/*"
      ],
      "@imgs/*": [
        "./public/img/*"
      ],
      "@pages/*": [
        "./public/pages/*"
      ],
      "@styles/*": [
        "./src/styles/*"
      ],
      "@scripts/*": [
        "./src/ts/*"
      ],
      "@core/*": [
        "./src/ts/core/*"
      ],
      "@projectCardManager/*": [
        "./src/ts/projectCardManager/*"
      ],
      "@data/*": [
        "./src/ts/projectCardManager/data/*"
      ],
      "@handlers/*": [
        "./src/ts/projectCardManager/handlers/*"
      ]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}