{
  "compilerOptions": {
    "target": "ES2015",
    "lib": ["ES2015", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/ts/core/*"],
      "@projectCardManager/*": ["src/ts/projectCardManager/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}